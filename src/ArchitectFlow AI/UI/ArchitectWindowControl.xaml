<UserControl x:Class="ArchitectFlowAI.UI.ArchitectWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             Background="{DynamicResource VsBrush.Window}"
             Foreground="{DynamicResource VsBrush.WindowText}">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="Foreground" Value="{DynamicResource VsBrush.WindowText}"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Background" Value="{DynamicResource VsBrush.ComboBoxBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource VsBrush.WindowText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource VsBrush.ComboBoxBorder}"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="0,4,8,4"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">

            <!-- ═══ TITOLO ═══ -->
            <TextBlock Text="ArchitectFlow AI"
                       FontSize="16" FontWeight="Bold"
                       Margin="0,0,0,2"/>
            <TextBlock Text="CQRS · Dapper · Mediator scaffolding"
                       FontSize="10" Opacity="0.7" Margin="0,0,0,16"/>

            <!-- ═══ A. INPUT LINKS ═══ -->
            <TextBlock Text="A  —  External Links" Style="{StaticResource SectionHeader}"/>
            <Separator Margin="0,0,0,8"/>

            <TextBlock Text="User Story / Jira link:" Margin="0,0,0,2"/>
            <TextBox x:Name="TxtUserStoryUrl"
                     Style="{StaticResource InputBox}"
                     ToolTip="URL della User Story o del ticket Jira/ADO"
                     Text="https://"/>

            <TextBlock Text="Design Wiki link:" Margin="0,4,0,2"/>
            <TextBox x:Name="TxtWikiUrl"
                     Style="{StaticResource InputBox}"
                     ToolTip="URL della pagina Confluence/Wiki con la query SQL"
                     Text="https://"/>

            <TextBlock Text="PAT (Personal Access Token):" Margin="0,4,0,2"/>
            <PasswordBox x:Name="PwdPat"
                         Padding="6,4"
                         Background="{DynamicResource VsBrush.ComboBoxBackground}"
                         ToolTip="Lascia vuoto per usare le credenziali Windows"/>

            <!-- ═══ B. PROJECT CONTEXT ═══ -->
            <TextBlock Text="B  —  Project Context" Style="{StaticResource SectionHeader}"/>
            <Separator Margin="0,0,0,8"/>

            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right"
                        Content="↺ Scan Solution"
                        Click="BtnScan_Click"
                        Padding="10,4"/>
                <TextBlock Text="Seleziona i progetti target:"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <Border BorderBrush="{DynamicResource VsBrush.ComboBoxBorder}"
                    BorderThickness="1" CornerRadius="2">
                <ListView x:Name="LvProjects"
                          Height="140"
                          SelectionMode="Multiple"
                          Background="{DynamicResource VsBrush.ComboBoxBackground}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Progetto" Width="160"
                                            DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Layer" Width="90"
                                            DisplayMemberBinding="{Binding Layer}"/>
                            <GridViewColumn Header="Namespace" Width="200"
                                            DisplayMemberBinding="{Binding RootNamespace}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- ═══ C. AZIONI ═══ -->
            <TextBlock Text="C  —  Actions" Style="{StaticResource SectionHeader}"/>
            <Separator Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnAnalyze"
                        Content="🔍  Analyze &amp; Sync"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnAnalyze_Click"
                        ToolTip="Scarica i link e valida la presenza di AC e SQL"/>

                <Button x:Name="BtnGenerate"
                        Content="⚡  Generate Code"
                        Style="{StaticResource PrimaryButton}"
                        IsEnabled="False"
                        Click="BtnGenerate_Click"
                        ToolTip="Invia il contesto a Copilot e genera i file"/>
            </StackPanel>

            <!-- ═══ PREVIEW PROMPT ═══ -->
            <TextBlock Text="Prompt Preview" Style="{StaticResource SectionHeader}"/>
            <Separator Margin="0,0,0,8"/>

            <TextBox x:Name="TxtPromptPreview"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Height="160"
                     FontFamily="Consolas"
                     FontSize="10"
                     Padding="6"
                     Background="{DynamicResource VsBrush.ComboBoxBackground}"
                     Foreground="{DynamicResource VsBrush.WindowText}"/>

            <!-- ═══ STATUS ═══ -->
            <TextBlock x:Name="TxtStatus"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       FontStyle="Italic"
                       Opacity="0.8"
                       Text="Pronto. Inserisci i link e premi Analyze &amp; Sync."/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
