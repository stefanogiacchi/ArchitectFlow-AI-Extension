<UserControl x:Class="ArchitectFlow_AI.ArchitectWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             Name="MyToolWindow">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="1. DOCUMENTAZIONE ESTERNA" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
            <Label Content="Link User Story (AC):" Foreground="Silver"/>
            <TextBox x:Name="TxtUserStoryLink" Margin="0,0,0,10" Background="#2D2D2D" Foreground="White" BorderBrush="#3F3F46"/>

            <Label Content="Link Design Wiki (SQL):" Foreground="Silver"/>
            <TextBox x:Name="TxtWikiLink" Margin="0,0,0,15" Background="#2D2D2D" Foreground="White" BorderBrush="#3F3F46"/>

            <TextBlock Text="2. CONTESTO SOLUZIONE" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
            <TextBlock Text="Seleziona i progetti target per il codice:" FontSize="10" Foreground="Gray" Margin="0,0,0,5"/>
            <ListBox x:Name="LstProjects" Height="150" SelectionMode="Multiple" Background="#2D2D2D" Foreground="White">
            </ListBox>

            <Button x:Name="BtnGenerate" Content="GENERA PROMPT ARCHITECT" 
                    Margin="0,20,0,0" Height="40" Background="#007ACC" Foreground="White" FontWeight="Bold"
                    Click="BtnGenerate_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
