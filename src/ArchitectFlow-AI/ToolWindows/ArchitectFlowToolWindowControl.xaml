<UserControl x:Class="ArchitectFlow_AI.ToolWindows.ArchitectFlowToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ArchitectFlow_AI.ToolWindows"
             xmlns:models="clr-namespace:ArchitectFlow_AI.Models"
             xmlns:viewModels="clr-namespace:ArchitectFlow_AI.Models"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="420"
             Background="{DynamicResource ToolWindowBackground}"
             Foreground="{DynamicResource ToolWindowForeground}"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver">

    <UserControl.Resources>
        <!-- Converters -->
        <local:LanguageToIconConverter x:Key="LangToIconConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisConverter"/>
        <local:InverseCountToVisibilityConverter x:Key="InvCountToVisConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <local:ProgressWidthConverter x:Key="ProgressWidthConverter"/>

        <!-- Brushes -->
        <SolidColorBrush x:Key="AccentBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="AccentDimBrush" Color="#4338CA"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="SurfaceOverlay" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2D2D3D"/>

        <!-- Styles -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDimBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pulsante outline -->
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource ToolWindowForeground}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SurfaceOverlay}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pulsante danger -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1AEF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="VsComboBox" TargetType="ComboBox">
            <Setter Property="Background"  Value="{DynamicResource ToolWindowBackground}"/>
            <Setter Property="Foreground"  Value="{DynamicResource ToolWindowForeground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Padding"     Value="6,3"/>
            <Setter Property="Height"      Value="24"/>
        </Style>

        <!-- TextBox prompt -->
        <Style x:Key="PromptBoxStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource ToolWindowBackground}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ToolWindowForeground}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="AcceptsReturn"   Value="True"/>
            <Setter Property="TextWrapping"    Value="Wrap"/>
            <Setter Property="Padding"         Value="8"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--
            DataTemplate per ogni ReferenceFile.
            Il Button "✕" usa SOLO <Button.Style> — nessun attributo Style
            esterno per evitare "property has already been set".
        -->
        <DataTemplate x:Key="ReferenceFileTemplate" DataType="{x:Type models:ReferenceFile}">
            <Border Margin="0,1" Padding="10,7"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderColor}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SurfaceOverlay}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icona linguaggio -->
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13"
                               Text="{Binding Language, Converter={StaticResource LangToIconConverter}}"/>

                    <!-- Nome + path -->
                    <StackPanel Grid.Column="1" Margin="6,0,6,0" VerticalAlignment="Center">
                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ToolWindowForeground}"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding FileName}"/>
                        <TextBlock FontSize="10" Foreground="{StaticResource MutedBrush}"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}  ·  {1}">
                                    <Binding Path="RelativePath"/>
                                    <Binding Path="SizeDisplay"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- Badge linguaggio -->
                    <Border Grid.Column="2" Margin="0,0,6,0"
                            Background="{StaticResource AccentDimBrush}"
                            CornerRadius="3" Padding="4,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Language}" FontSize="9" Foreground="#A5B4FC"/>
                    </Border>

                    <!--
                        Pulsante rimuovi.
                        Pulsante rimuovi.
                        REGOLA: nessun attributo Style="..." — usa solo <Button.Style>.
                        La visibilità è gestita tramite DataTrigger su IsMouseOver del Border padre.
                    -->
                    <Button Grid.Column="3" Content="✕"
                            ToolTip="Rimuovi riferimento"
                            Tag="{Binding FullPath}"
                            Click="OnRemoveReferenceClick"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                <Setter Property="Visibility" Value="Hidden"/>
                                <Style.Triggers>
                                    <DataTrigger Value="True"
                                                 Binding="{Binding IsMouseOver,
                                                           RelativeSource={RelativeSource AncestorType=Border,
                                                                           AncestorLevel=1}}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <!-- ════════════════════════════════ LAYOUT ════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0  Header -->
            <RowDefinition Height="Auto"/>
            <!-- 1  Binding indicator -->
            <RowDefinition Height="Auto"/>
            <!-- 2  Reference header -->
            <RowDefinition Height="Auto"/>
            <!-- 3  Reference list -->
            <RowDefinition Height="Auto"/>
            <!-- 4  #file: preview -->
            <RowDefinition Height="5"/>
            <!-- 5  Drag handle -->
            <RowDefinition Height="Auto"/>
            <!-- 6  Mode / Output selectors -->
            <RowDefinition Height="110"/>
            <!-- 7  Prompt -->
            <RowDefinition Height="Auto"/>
            <!-- 8  Prompt actions -->
            <RowDefinition Height="Auto"/>
            <!-- 9  Agent Loop panel -->
            <RowDefinition Height="1"/>
            <!-- 10 Separator -->
            <RowDefinition Height="*"/>
            <!-- 11 Output -->
        </Grid.RowDefinitions>

        <!-- 0 · HEADER -->
        <Border Grid.Row="0" Padding="12,10"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderColor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="16" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="ArchitectFlow AI" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource ToolWindowForeground}"/>
                        <TextBlock Text="CQRS · Dapper · Mediator"
                                   FontSize="9" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource OutlineButton}"
                            Content="⚙" Padding="6,3" Margin="0,0,4,0"
                            Click="OnOpenSettingsClick"/>
                    <Button Style="{StaticResource DangerButton}"
                            Content="🗑 Svuota"
                            IsEnabled="{Binding HasReferences}"
                            Click="OnClearAllClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 1 · BINDING INDICATOR -->
        <Border Grid.Row="1" Padding="12,6"
                Background="#1A6366F1"
                BorderThickness="0,0,0,1" BorderBrush="#336366F1"
                Visibility="{Binding ReferenceCount, Converter={StaticResource CountToVisConverter}}">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}"
                         VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock FontSize="11" Foreground="#A5B4FC">
                    <Run Text="{Binding ReferenceCount, Mode=OneWay}"/>
                    <Run Text=" file vincolanti — il codice seguirà questi pattern"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 2 · REFERENCE PANEL HEADER -->
        <Border Grid.Row="2" Padding="12,5"
                Background="{StaticResource SurfaceOverlay}"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderColor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📎" Margin="0,0,6,0"/>
                    <TextBlock Text="FILE DI RIFERIMENTO" FontSize="10" FontWeight="Bold"
                               Opacity="0.65" VerticalAlignment="Center"
                               Foreground="{DynamicResource ToolWindowForeground}"/>
                </StackPanel>
                <Border Grid.Column="1" Margin="0,0,8,0"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="10" Padding="6,1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ReferenceCount}"
                               FontSize="10" FontWeight="Bold" Foreground="White"/>
                </Border>
                <Button Grid.Column="2" Style="{StaticResource OutlineButton}"
                        Content="{Binding CollapseIcon}" Padding="4,2" FontSize="10"
                        Click="OnToggleRefPanelClick"/>
            </Grid>
        </Border>

        <!-- 3 · REFERENCE LIST -->
        <Border Grid.Row="3" MaxHeight="{Binding RefPanelMaxHeight}"
                Visibility="{Binding RefPanelCollapsed, Converter={StaticResource BoolToVisConverter}, ConverterParameter=inverse}">
            <Grid>
                <!-- Empty state -->
                <Border Padding="20"
                        Visibility="{Binding ReferenceCount, Converter={StaticResource InvCountToVisConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📂" FontSize="32" TextAlignment="Center"
                                   HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Margin="0,10,0,0" TextAlignment="Center"
                                   FontSize="11" Opacity="0.45" TextWrapping="Wrap"
                                   Foreground="{DynamicResource ToolWindowForeground}">
                            Clic destro su file/cartelle nella Solution Explorer<LineBreak/>
                            → <Bold>Aggiungi a ArchitectFlow References</Bold><LineBreak/><LineBreak/>
                            oppure trascina qui i file.
                        </TextBlock>
                        <Button Style="{StaticResource OutlineButton}"
                                Content="+ Sfoglia file…" Margin="0,12,0,0"
                                HorizontalAlignment="Center" Click="OnBrowseFilesClick"/>
                    </StackPanel>
                </Border>

                <!-- Populated list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding ReferenceCount, Converter={StaticResource CountToVisConverter}}">
                    <ItemsControl ItemsSource="{Binding ReferenceFiles}"
                                  ItemTemplate="{StaticResource ReferenceFileTemplate}"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 4 · #FILE: PREVIEW -->
        <Border Grid.Row="4" Padding="12,7"
                Background="#0D6366F1"
                BorderThickness="3,0,0,0"
                BorderBrush="{StaticResource AccentBrush}"
                Visibility="{Binding ReferenceCount, Converter={StaticResource CountToVisConverter}}">
            <StackPanel>
                <TextBlock Text="VERRÀ INIETTATO IN COPILOT:" FontSize="9"
                           FontWeight="Bold" Opacity="0.55" Margin="0,0,0,4"
                           Foreground="{DynamicResource ToolWindowForeground}"/>
                <ItemsControl ItemsSource="{Binding ReferenceFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontFamily="Consolas" FontSize="10"
                                       Foreground="#818CF8" TextTrimming="CharacterEllipsis">
                                <Run Text="#file:'"/><Run Text="{Binding FullPath}"/><Run Text="'"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 5 · DRAG HANDLE -->
        <Border Grid.Row="5" Background="{StaticResource BorderColor}" Cursor="SizeNS"/>

        <!-- 6 · MODE / OUTPUT -->
        <Border Grid.Row="6" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderColor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="MODALITÀ" FontSize="9" FontWeight="Bold" Opacity="0.55"
                               Margin="0,0,0,3" Foreground="{DynamicResource ToolWindowForeground}"/>
                    <ComboBox x:Name="ModeCombo" Style="{StaticResource VsComboBox}"
                              SelectionChanged="OnModeChanged">
                        <ComboBoxItem Content="🏗 CQRS Command"       Tag="cqrs_command"  IsSelected="True"/>
                        <ComboBoxItem Content="🔍 CQRS Query"          Tag="cqrs_query"/>
                        <ComboBoxItem Content="🌐 API Endpoint"        Tag="api_endpoint"/>
                        <ComboBoxItem Content="🗄 Repository (Dapper)" Tag="repository"/>
                        <ComboBoxItem Content="📊 Dapper SQL Query"    Tag="dapper_query"/>
                        <ComboBoxItem Content="⚙ MediatR Handler"     Tag="handler"/>
                        <ComboBoxItem Content="✍ Freeform"            Tag="freeform"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="OUTPUT" FontSize="9" FontWeight="Bold" Opacity="0.55"
                               Margin="0,0,0,3" Foreground="{DynamicResource ToolWindowForeground}"/>
                    <ComboBox x:Name="OutputCombo" Style="{StaticResource VsComboBox}">
                        <ComboBoxItem Content="📋 Pannello output" Tag="panel"         IsSelected="True"/>
                        <ComboBoxItem Content="📄 Nuovo file .cs"  Tag="new_file"/>
                        <ComboBoxItem Content="📝 Editor attivo"   Tag="active_editor"/>
                        <ComboBoxItem Content="📋 Clipboard"       Tag="clipboard"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 6 · PROMPT -->
        <Grid Grid.Row="7" Margin="12,8">
            <TextBox x:Name="PromptBox"
                         Style="{StaticResource PromptBoxStyle}"
                         Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="OnPromptKeyDown"/>
            <TextBlock IsHitTestVisible="False" Padding="10,10,10,0"
                       FontFamily="Consolas" FontSize="12"
                       Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                       Visibility="{Binding IsPromptEmpty, Converter={StaticResource BoolToVisConverter}}">
                Descrivi il codice da generare…<LineBreak/>
                Es: "CreateOrderCommand con FluentValidation"<LineBreak/>
                (Ctrl+Invio per generare)
            </TextBlock>
        </Grid>

        <!-- 7 · PROMPT ACTIONS -->
        <Border Grid.Row="8" Padding="12,6"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderColor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           FontSize="10" Foreground="{StaticResource MutedBrush}">
                    <Run Text="Ctrl+Invio · "/>
                    <Run Text="{Binding ReferenceCount, Mode=OneWay}"
                         Foreground="{StaticResource AccentBrush}"/>
                    <Run Text=" ref attivi"/>
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource OutlineButton}"
                            Content="🗑" Padding="6,4" Margin="0,0,6,0"
                            ToolTip="Pulisci prompt"
                            Click="OnClearPromptClick"/>
                    <!--
                        Copia negli appunti il prompt completo con i riferimenti #file:'path'
                        per ogni file selezionato. L'utente può incollarlo manualmente
                        in Copilot Chat (Ctrl+V → Invio) senza usare il loop automatico.
                    -->
                    <Button Style="{StaticResource OutlineButton}"
                            Content="📎 Copia prompt" Padding="8,4" Margin="0,0,6,0"
                            ToolTip="Copia il prompt con i riferimenti #file: negli appunti.&#x0a;Incolla manualmente in Copilot Chat con Ctrl+V."
                            IsEnabled="{Binding CanGenerate}"
                            Click="OnCopyPromptClick"/>
                    <Button Style="{StaticResource DangerButton}"
                            Content="⏹ Stop" Padding="10,4" Margin="0,0,6,0"
                            IsEnabled="{Binding IsGenerating}"
                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisConverter}}"
                            Click="OnStopClick"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding CanGenerate}" Click="OnGenerateClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✨" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding GenerateButtonLabel}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ AGENT LOOP PANEL ══════════════════════════════════════════ -->
        <!--
            Il pannello del loop agente si trova tra le azioni prompt e l'output.
            Mostra: pulsante avvio/stop, max iterazioni, progresso iterazione corrente,
            indicatore di fase (inject / build / done / error), badge errori.
        -->
        <Border Grid.Row="9" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderColor}">
            <Expander IsExpanded="True">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🤖" Margin="0,0,6,0"/>
                        <TextBlock Text="COPILOT LOOP" FontSize="10" FontWeight="Bold"
                                   Opacity="0.65"
                                   Foreground="{DynamicResource ToolWindowForeground}"
                                   VerticalAlignment="Center"/>
                        <!-- Badge "RUNNING" -->
                        <Border Margin="8,0,0,0"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="3" Padding="5,1"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsLoopRunning, Converter={StaticResource BoolToVisConverter}}">
                            <TextBlock Text="● IN ESECUZIONE" FontSize="8" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Expander.Header>

                <StackPanel Margin="12,4,12,10">

                    <!-- Riga 1: Configurazione max iterazioni + pulsante avvio/stop -->
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Max iterazioni:"
                                   FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ToolWindowForeground}"/>
                        <TextBox Grid.Column="1" Width="40" Margin="6,0,12,0"
                                 Text="{Binding LoopMaxIterations, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="11" Padding="4,2"
                                 Background="{DynamicResource ToolWindowBackground}"
                                 Foreground="{DynamicResource ToolWindowForeground}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 VerticalContentAlignment="Center"/>

                        <!-- Pulsante Avvia / Stop -->
                        <Button Grid.Column="3" Padding="12,5"
                                Click="OnStartLoopClick">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoopRunning}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LoopPhaseIcon}" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding LoopButtonLabel}"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Riga 2: Barra progresso iterazioni -->
                    <Grid Margin="0,8,0,0"
                          Visibility="{Binding IsLoopRunning, Converter={StaticResource BoolToVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Height="6" CornerRadius="3"
                                Background="{StaticResource BorderColor}">
                            <Border CornerRadius="3" Background="{StaticResource AccentBrush}"
                                    HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource ProgressWidthConverter}">
                                        <Binding Path="LoopIteration"/>
                                        <Binding Path="LoopMaxIterations"/>
                                        <Binding Path="ActualWidth"
                                                 RelativeSource="{RelativeSource AncestorType=Border,
                                                                  AncestorLevel=1}"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>

                        <TextBlock Grid.Column="1" Margin="8,0,0,0"
                                   FontSize="10" Foreground="{StaticResource MutedBrush}"
                                   Text="{Binding LoopProgressText}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Riga 3: Errori correnti -->
                    <Border Margin="0,6,0,0" Padding="8,5"
                            Background="#1AEF4444" CornerRadius="4"
                            Visibility="{Binding LoopErrorCount, Converter={StaticResource CountToVisConverter}}">
                        <TextBlock FontSize="11" Foreground="{StaticResource DangerBrush}">
                            <Run Text="⚠ "/>
                            <Run Text="{Binding LoopErrorCount, Mode=OneWay}"/>
                            <Run Text=" errori di compilazione — Copilot sta correggendo…"/>
                        </TextBlock>
                    </Border>

                </StackPanel>
            </Expander>
        </Border>

        <!-- 9 · SEPARATOR -->
        <Border Grid.Row="10" Background="{StaticResource BorderColor}"/>

        <!-- 10 · OUTPUT -->
        <Grid Grid.Row="11">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Output header -->
            <Border Grid.Row="0" Padding="12,6"
                    Background="{StaticResource SurfaceOverlay}"
                    BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderColor}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="OUTPUT" FontSize="10" FontWeight="Bold" Opacity="0.6"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ToolWindowForeground}"/>
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0"
                                    Visibility="{Binding IsGenerating,
                                                 Converter={StaticResource BoolToVisConverter}}">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                     VerticalAlignment="Center" Margin="0,0,4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.2"
                                                                         Duration="0:0:0.6" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="Generazione in corso…" FontSize="10"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource OutlineButton}" Content="📋 Copia"
                                Padding="6,3" Margin="0,0,4,0" FontSize="10"
                                IsEnabled="{Binding HasOutput}" Click="OnCopyOutputClick"/>
                        <Button Style="{StaticResource OutlineButton}" Content="⬆ Inserisci"
                                Padding="6,3" Margin="0,0,4,0" FontSize="10"
                                IsEnabled="{Binding HasOutput}" Click="OnInsertToEditorClick"/>
                        <Button Style="{StaticResource OutlineButton}" Content="💾 Salva .cs"
                                Padding="6,3" FontSize="10"
                                IsEnabled="{Binding HasOutput}" Click="OnSaveAsFileClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Output text area -->
            <Grid Grid.Row="1">
                <ScrollViewer x:Name="OutputScroll" VerticalScrollBarVisibility="Auto">
                    <TextBox IsReadOnly="True" FontFamily="Consolas" FontSize="11.5"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource ToolWindowForeground}"
                             Text="{Binding OutputText, Mode=OneWay}"
                             TextWrapping="Wrap" Padding="12,10"/>
                </ScrollViewer>
                <!-- Placeholder vuoto -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Opacity="0.25" IsHitTestVisible="False"
                            Visibility="{Binding HasOutput,
                                         Converter={StaticResource BoolToVisConverter},
                                         ConverterParameter=inverse}">
                    <TextBlock Text="⚡" FontSize="40" TextAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Il codice generato apparirà qui" FontSize="12"
                               TextAlignment="Center" Margin="0,8,0,0"
                               Foreground="{DynamicResource ToolWindowForeground}"/>
                </StackPanel>
            </Grid>

            <!-- Status -->
            <Border Grid.Row="2" Padding="12,4"
                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderColor}">
                <TextBlock FontSize="10" Foreground="{StaticResource MutedBrush}"
                           Text="{Binding StatusText}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
